# Google OAuth Allowed Emails (comma separated list)
VITE_ALLOWED_EMAILS="email@gmail.com,another_admin@gmail.com"

# Shared / Default Firebase credentials (used for Auth and fallback)
VITE_FIREBASE_API_KEY="AIzaSy..."
VITE_FIREBASE_AUTH_DOMAIN="project-name.firebaseapp.com"
VITE_FIREBASE_PROJECT_ID="project-name"
VITE_FIREBASE_STORAGE_BUCKET="project-name.firebasestorage.app"
VITE_FIREBASE_MESSAGING_SENDER_ID=""
VITE_FIREBASE_APP_ID=""

# =============================================================================
# OPTION A: Same Firebase Project, different Firestore databases/collections (Default Setup)
# =============================================================================
# Dev environment Firestore config
VITE_FIRESTORE_DATABASE_DEV="(default)"
VITE_FIRESTORE_COLLECTION_DEV="feature_flags_dev"

# Prod environment Firestore config
VITE_FIRESTORE_DATABASE_PROD="(default)"
VITE_FIRESTORE_COLLECTION_PROD="feature_flags_prod"

# =============================================================================
# OPTION B: (Optional) Different Firebase Projects (e.g. your-project-dev and your-project-prod)
# Un-comment and fill these if you use separate GCP/Firebase projects.
# =============================================================================
# VITE_FIREBASE_API_KEY_DEV="AIzaSy..."
# VITE_FIREBASE_AUTH_DOMAIN_DEV="your-project-dev.firebaseapp.com"
# VITE_FIREBASE_PROJECT_ID_DEV="your-project-dev"
# VITE_FIREBASE_STORAGE_BUCKET_DEV="your-project-dev.firebasestorage.app"
# VITE_FIREBASE_MESSAGING_SENDER_ID_DEV="12345678"
# VITE_FIREBASE_APP_ID_DEV="1:12345678:web:abcd..."

# VITE_FIREBASE_API_KEY_PROD="AIzaSy..."
# VITE_FIREBASE_AUTH_DOMAIN_PROD="your-project-prod.firebaseapp.com"
# VITE_FIREBASE_PROJECT_ID_PROD="your-project-prod"
# VITE_FIREBASE_STORAGE_BUCKET_PROD="your-project-prod.firebasestorage.app"
# VITE_FIREBASE_MESSAGING_SENDER_ID_PROD="87654321"
# VITE_FIREBASE_APP_ID_PROD="1:87654321:web:dcba..."
